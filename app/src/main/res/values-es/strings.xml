    <string name="voicekb_smart_insertion_settings_summary">Ajustar mayúsculas antes de insertar el texto transcrito</string>
    <string name="voicekb_smart_insertion_description">VoiceKB lee una pequeña parte del texto antes del cursor y ajusta el inicio de la transcripción antes de insertarla. Solo se cambia la primera letra de la primera palabra y un posible espacio inicial.</string>
    <string name="voicekb_smart_insertion_sentence_summary">Los finales de frase se detectan por ., !, ?, …, incluidas comillas o paréntesis de cierre después del signo. Si el editor no proporciona texto antes del cursor, VoiceKB inserta la transcripción sin cambios.</string>
    <string name="voicekb_smart_insertion_preserve_abbreviations_title">Mantener abreviaturas sin cambios</string>
    <string name="voicekb_smart_insertion_preserve_abbreviations_summary">Una abreviatura es una palabra con al menos dos letras mayúsculas.</string>
    <string name="voicekb_smart_insertion_capitalize_after_sentence_title">Mayúscula tras final de frase o contexto vacío</string>
    <string name="voicekb_smart_insertion_capitalize_after_sentence_summary">Pone la primera letra en mayúscula cuando no hay texto previo o la frase anterior ha terminado.</string>
    <string name="voicekb_smart_insertion_lowercase_unfinished_title">Minúscula dentro de una frase sin terminar</string>
    <string name="voicekb_smart_insertion_lowercase_unfinished_summary">Pone la primera letra en minúscula cuando la frase anterior no ha terminado.</string>
    <string name="voicekb_smart_insertion_markdown_list_title">Mayúscula tras marcador de lista Markdown</string>
    <string name="voicekb_smart_insertion_markdown_list_summary">Mantiene los elementos de lista con mayúscula tras marcadores como -, +, *, - [ ] o - [x] seguidos de un espacio.</string>
    <string name="voicekb_smart_insertion_quote_title">Mayúscula tras marcador de cita</string>
    <string name="voicekb_smart_insertion_quote_summary">Mantiene el texto citado con mayúscula tras el marcador de cita Markdown &gt; seguido de un espacio.</string>
    <string name="voicekb_smart_insertion_blacklist_title">Lista negra para conservar mayúsculas</string>
    <string name="voicekb_smart_insertion_blacklist_summary">Una palabra por línea. Si una palabra contiene apóstrofo, solo se comprueba la parte anterior al apóstrofo.</string>
