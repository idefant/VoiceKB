    <string name="voicekb_smart_insertion_settings_summary">Ajustar maiúsculas antes de inserir o texto transcrito</string>
    <string name="voicekb_smart_insertion_description">O VoiceKB lê uma pequena parte do texto antes do cursor e ajusta o início da transcrição antes de inseri-la. Apenas a primeira letra da primeira palavra e um possível espaço inicial são alterados.</string>
    <string name="voicekb_smart_insertion_sentence_summary">Finais de frase são detectados por ., !, ?, …, incluindo aspas ou parênteses de fechamento após a pontuação. Se o editor não fornecer texto antes do cursor, o VoiceKB insere a transcrição sem alterações.</string>
    <string name="voicekb_smart_insertion_preserve_abbreviations_title">Manter abreviações sem alterações</string>
    <string name="voicekb_smart_insertion_preserve_abbreviations_summary">Uma abreviação é uma palavra com pelo menos duas letras maiúsculas.</string>
    <string name="voicekb_smart_insertion_capitalize_after_sentence_title">Maiúscula após fim de frase ou contexto vazio</string>
    <string name="voicekb_smart_insertion_capitalize_after_sentence_summary">Torna a primeira letra maiúscula quando não há texto anterior ou a frase anterior terminou.</string>
    <string name="voicekb_smart_insertion_lowercase_unfinished_title">Minúscula dentro de frase inacabada</string>
    <string name="voicekb_smart_insertion_lowercase_unfinished_summary">Torna a primeira letra minúscula quando a frase anterior não terminou.</string>
    <string name="voicekb_smart_insertion_markdown_list_title">Maiúscula após marcador de lista Markdown</string>
    <string name="voicekb_smart_insertion_markdown_list_summary">Mantém itens de lista com maiúscula após marcadores como -, +, *, - [ ] ou - [x] seguidos de espaço.</string>
    <string name="voicekb_smart_insertion_quote_title">Maiúscula após marcador de citação</string>
    <string name="voicekb_smart_insertion_quote_summary">Mantém texto citado com maiúscula após o marcador de citação Markdown &gt; seguido de espaço.</string>
    <string name="voicekb_smart_insertion_blacklist_title">Lista de preservação de maiúsculas</string>
    <string name="voicekb_smart_insertion_blacklist_summary">Uma palavra por linha. Se uma palavra contiver apóstrofo, apenas a parte antes do apóstrofo será verificada.</string>
