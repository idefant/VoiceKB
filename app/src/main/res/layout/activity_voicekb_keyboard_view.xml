<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/voicekb_keyboard_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/voicekb_keyboard_surface_light">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/info_cl"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_keyboard_info"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="gone">

        <TextView
            android:id="@+id/info_tv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/voicekb_red"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/info_yes_btn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/info_yes_btn"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:foreground="@drawable/ic_baseline_check_circle_outline_24"
            android:foregroundGravity="center"
            android:visibility="gone"
            app:layout_constraintEnd_toStartOf="@id/info_no_btn"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible" />

        <Button
            android:id="@+id/info_no_btn"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:foreground="@drawable/ic_baseline_not_interested_24"
            android:foregroundGravity="center"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/keyboard_header"
        android:layout_width="0dp"
        android:layout_height="46dp"
        android:background="@color/voicekb_keyboard_header_light"
        android:paddingHorizontal="14dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/info_cl">

        <View
            android:id="@+id/voicekb_status_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_status_dot"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/voicekb_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/app_name"
            android:textColor="@color/voicekb_keyboard_text_light"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/voicekb_status_dot"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/debug_badge"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_debug_badge"
            android:gravity="center"
            android:paddingHorizontal="7dp"
            android:text="DEV"
            android:textColor="@color/voicekb_white"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/voicekb_title"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/language_btn"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="29dp"
            android:layout_marginStart="12dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="9dp"
            android:paddingEnd="7dp"
            android:text="@string/voicekb_detect_short"
            android:textColor="@color/voicekb_keyboard_primary_pressed"
            android:textSize="10sp"
            android:textStyle="bold"
            app:backgroundTint="@color/voicekb_keyboard_language_light"
            app:cornerRadius="10dp"
            app:icon="@drawable/ic_lucide_chevron_down_24"
            app:iconGravity="textEnd"
            app:iconPadding="4dp"
            app:iconSize="14dp"
            app:iconTint="@color/voicekb_keyboard_language_icon"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/debug_badge"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_btn"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/voicekb_quick_settings"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="8dp"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_lucide_settings_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="20dp"
            app:iconTint="@color/voicekb_keyboard_icon_light"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/return_previous_btn"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/return_previous_btn"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/voicekb_return_to_previous_keyboard"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="8dp"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_lucide_clock_4_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="20dp"
            app:iconTint="@color/voicekb_keyboard_icon_light"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/language_btn"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/edit_redo_btn"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:contentDescription="@string/voicekb_redo"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="8dp"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_lucide_redo_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="20dp"
            app:iconTint="@color/voicekb_keyboard_icon_light"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/edit_undo_btn"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginEnd="13dp"
            android:contentDescription="@string/voicekb_undo"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="8dp"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_lucide_undo_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="20dp"
            app:iconTint="@color/voicekb_keyboard_icon_light"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/edit_redo_btn"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/keyboard_surface"
        android:layout_width="0dp"
        android:layout_height="194dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/keyboard_header">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/keyboard_primary_row"
            android:layout_width="0dp"
            android:layout_height="106dp"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="14dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/file_transcription_btn"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/voicekb_file_transcription"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="13dp"
                android:visibility="invisible"
                app:backgroundTint="@color/voicekb_keyboard_button_light"
                app:cornerRadius="15dp"
                app:icon="@drawable/ic_lucide_file_volume_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="21dp"
                app:iconTint="@color/voicekb_keyboard_icon_light"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/resend_btn"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/voicekb_resend"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="13dp"
                android:visibility="invisible"
                app:backgroundTint="@color/voicekb_keyboard_button_light"
                app:cornerRadius="15dp"
                app:icon="@drawable/ic_lucide_refresh_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="21dp"
                app:iconTint="@color/voicekb_keyboard_icon_light"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/trash_btn"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="13dp"
                android:contentDescription="@string/voicekb_reset_recording"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="13dp"
                android:visibility="invisible"
                app:backgroundTint="@color/voicekb_keyboard_danger_container_light"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_lucide_trash_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="20dp"
                app:iconTint="@color/voicekb_red"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/record_container"
                app:layout_constraintTop_toTopOf="parent"
                tools:visibility="visible" />

            <FrameLayout
                android:id="@+id/record_container"
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:layout_marginTop="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/record_btn"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:contentDescription="@string/voicekb_record"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="22dp"
                    app:backgroundTint="@color/voicekb_keyboard_primary"
                    app:cornerRadius="46dp" />

                <ImageView
                    android:id="@+id/record_icon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="26dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_lucide_mic_24"
                    app:tint="@color/voicekb_white" />

                <ImageView
                    android:id="@+id/record_bluetooth_badge"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="17dp"
                    android:layout_marginEnd="15dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_baseline_bluetooth_20"
                    android:visibility="gone"
                    app:tint="@color/voicekb_white" />

                <TextView
                    android:id="@+id/record_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal|bottom"
                    android:layout_marginBottom="12dp"
                    android:textColor="@color/voicekb_white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="00:07"
                    tools:visibility="visible" />

                <ProgressBar
                    android:id="@+id/record_progress"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="33dp"
                    android:layout_height="33dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/voicekb_white"
                    android:visibility="gone" />
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pause_btn"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="13dp"
                android:contentDescription="@string/voicekb_voice_pause_button"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="13dp"
                android:visibility="invisible"
                app:backgroundTint="@color/voicekb_keyboard_button_light"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_lucide_pause_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="20dp"
                app:iconTint="@color/voicekb_keyboard_icon_light"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/record_container"
                app:layout_constraintTop_toTopOf="parent"
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/backspace_btn"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/voicekb_backspace"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="13dp"
                app:backgroundTint="@color/voicekb_keyboard_button_light"
                app:cornerRadius="15dp"
                app:icon="@drawable/ic_lucide_delete_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="22dp"
                app:iconTint="@color/voicekb_keyboard_icon_light"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/keyboard_bottom_row"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/keyboard_primary_row">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/switch_btn"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/voicekb_change_input_method"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="13dp"
                app:backgroundTint="@color/voicekb_keyboard_button_light"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_lucide_keyboard_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="20dp"
                app:iconTint="@color/voicekb_keyboard_icon_light" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/space_btn"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="10dp"
                android:layout_weight="1"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:text="@string/voicekb_space"
                android:textAllCaps="false"
                android:textColor="@color/voicekb_keyboard_muted_text_light"
                android:textSize="11sp"
                app:backgroundTint="@color/voicekb_keyboard_button_light"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/enter_btn"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/voicekb_enter"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="13dp"
                app:backgroundTint="@color/voicekb_keyboard_enter_light"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_lucide_corner_down_left_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="21dp"
                app:iconTint="@color/voicekb_keyboard_primary_pressed" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/special_characters_scrim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/voicekb_keyboard_scrim"
        android:clickable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/overlay_characters_ll"
        android:layout_width="wrap_content"
        android:layout_height="59dp"
        android:layout_marginBottom="85dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/bg_special_characters_tray"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="9dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
