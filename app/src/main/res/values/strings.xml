    <string name="voicekb_smart_insertion_title">Smart insertion</string>
    <string name="voicekb_smart_insertion_settings_summary">Adjust capitalization before inserting transcribed text</string>
    <string name="voicekb_smart_insertion_description">VoiceKB reads a small part of the text before the cursor and adjusts the beginning of the transcription before inserting it. Only the first letter of the first word and a possible leading space are changed.</string>
    <string name="voicekb_smart_insertion_sentence_summary">Sentence endings are detected by ., !, ?, …, including closing quotes or brackets after the punctuation mark. If the current editor does not provide text before the cursor, VoiceKB inserts the transcription unchanged.</string>
    <string name="voicekb_smart_insertion_preserve_abbreviations_title">Keep abbreviations unchanged</string>
    <string name="voicekb_smart_insertion_preserve_abbreviations_summary">An abbreviation is a word with at least two uppercase letters.</string>
    <string name="voicekb_smart_insertion_capitalize_after_sentence_title">Capitalize after sentence end or empty context</string>
    <string name="voicekb_smart_insertion_capitalize_after_sentence_summary">Make the first letter uppercase when there is no previous text or the previous sentence is finished.</string>
    <string name="voicekb_smart_insertion_lowercase_unfinished_title">Lowercase inside unfinished sentence</string>
    <string name="voicekb_smart_insertion_lowercase_unfinished_summary">Make the first letter lowercase when the previous sentence is not finished.</string>
    <string name="voicekb_smart_insertion_markdown_list_title">Capitalize after Markdown list marker</string>
    <string name="voicekb_smart_insertion_markdown_list_summary">Keep list items capitalized after markers like -, +, *, - [ ], or - [x] followed by a space.</string>
    <string name="voicekb_smart_insertion_quote_title">Capitalize after quote marker</string>
    <string name="voicekb_smart_insertion_quote_summary">Keep quoted text capitalized after the Markdown quote marker &gt; followed by a space.</string>
    <string name="voicekb_smart_insertion_blacklist_title">Case-preserve blacklist</string>
    <string name="voicekb_smart_insertion_blacklist_summary">One word per line. If a word contains an apostrophe, only the part before the apostrophe is checked.</string>
