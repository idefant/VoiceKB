    <string name="voicekb_onboarding_groq_instruction_html"><![CDATA[
        Groq is fast and has a free tier that is usually enough to try VoiceKB.<br><br>
        1. Open <a href="https://console.groq.com/keys">Groq API Keys</a>.<br>
        2. Create a new key.<br>
        3. Paste the key below. It usually starts with <b>gsk_</b>.
    ]]></string>
    <string name="voicekb_onboarding_openai_instruction_html"><![CDATA[
        OpenAI is the official provider for OpenAI transcription models. Usage may require paid API credits.<br><br>
        1. Open <a href="https://platform.openai.com/api-keys">OpenAI API Keys</a>.<br>
        2. Create a new secret key.<br>
        3. Paste the key below. It usually starts with <b>sk-</b>.
    ]]></string>
